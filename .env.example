# Only needed in production for persistent storage.
# In Vercel: go to your project -> Storage tab -> Marketplace -> add a free
# "Redis" integration (e.g. Upstash) -> Connect to this project.
# Vercel injects these automatically once connected — you don't need to set
# them by hand for a normal deploy. They're listed here just for reference
# and for running against a remote Redis store locally if you ever want to.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Some integration versions use these names instead — either pair works:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
